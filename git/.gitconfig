[init]
	defaultBranch = main
[user]
        name = SerAbinU1
        email = abinyt1234@gmail.com
[pull]
        rebase = true
[core]
        editor = nvim
        autocrlf = input
	pager = delta
[push]
        autoSetupRemote = true
[rerere]
	enabled = true
[diff]
	algorithm = histogram
[merge]
	conflictstyle = zdiff3
[delta]
	side-by-side = true
